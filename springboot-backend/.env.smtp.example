# SADECE ORNEK DOSYA - Spring Boot bunu OKUMAZ.
# Gercek ayarlar icin kopyalayin: .env.smtp.example -> .env.smtp
# .env.smtp gitignore'da; sifreler repoya gitmez.
#
# NOT: backend/.env (Python) ve frontend/.env.local (Next.js) SMTP icin KULLANILMAZ.

# SMTP server settings
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USERNAME=your_smtp_username_here
SMTP_PASSWORD=your_smtp_password_here

# JavaMail properties (optional; defaults are already set in application.yml)
SMTP_AUTH=true
SMTP_STARTTLS_ENABLE=true
SMTP_STARTTLS_REQUIRED=true
SMTP_CONNECTION_TIMEOUT_MS=5000
SMTP_TIMEOUT_MS=5000
SMTP_WRITE_TIMEOUT_MS=5000

# From address used in outgoing verification and password reset emails
SMTP_FROM=no-reply@example.com

# Optional auth settings (production defaults in application.yml)
# GOOGLE_CLIENT_ID=your_google_client_id_here
# AUTH_PREVIEW_RESET_TOKEN=false
# AUTH_PREVIEW_VERIFICATION_TOKEN=false
# AUTH_RESET_PASSWORD_URL_BASE=https://your-domain.com
# AUTH_VERIFICATION_URL_BASE=https://your-domain.com

# Notes:
# - Replace SMTP_PASSWORD with the actual secret in your local .env.smtp or secret store.
# - For Brevo/Sendinblue SMTP, use the SMTP username and password provided by the service.
# - In production, prefer Docker secrets or an environment secret manager instead of a plaintext file.
